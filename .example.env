# The Doom Signal environment example.
# Copy this file to .env for local development, then replace placeholders.
# Never commit real secrets, wallet private keys, or production database URLs.

# Required: Postgres connection.
# Local example: postgresql://postgres:postgres@localhost:5432/agent_arena?schema=public
# Production: use a pooled Neon/Supabase/Vercel Postgres connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Required in production: public app URL used in generated links and 6529 posts.
# Local default is usually http://localhost:3000 or http://localhost:5001.
NEXT_PUBLIC_APP_URL="http://localhost:5001"

# Keep true for the simple launch. Set false only when you want battles,
# submissions, wallet linking, and self-test surfaces visible.
SIMPLE_LAUNCH_MODE="true"

# Optional until public wallet flows are enabled.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# 6529 API and bot posting.
6529_API_BASE_URL="https://api.6529.io"
6529_MOCK_MODE="false"
6529_BOT_WALLET_ADDRESS="0xYOUR_DEDICATED_BOT_WALLET"
6529_BOT_PRIVATE_KEY="0xYOUR_DEDICATED_BOT_PRIVATE_KEY"
6529_BOT_HANDLE="testing12345"

# AI provider keys. Local development defaults to Ollama; production should use a hosted provider.
# Set OPENAI_API_KEY if WAVE_BRIEF_PROVIDER=openai.
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY=""
OLLAMA_BASE_URL="http://127.0.0.1:11434"
AI_PROVIDER_TIMEOUT_MS="45000"
OLLAMA_PROVIDER_TIMEOUT_MS="120000"
AI_PROVIDER_RETRIES="1"

# Wave check-in generation.
WAVE_BRIEF_PROVIDER="ollama"
WAVE_BRIEF_LOCAL_MOCK_MODE="false"
WAVE_BRIEF_MODEL="qwen3:14b"
MAX_WAVE_BRIEF_ESTIMATED_COST_USD="0.25"
WAVE_BRIEF_RATE_LIMIT_PER_HOUR="10"

# Feature-gated evaluation/battle systems.
MAX_BATTLE_ESTIMATED_COST_USD="1"
SELF_TEST_ENABLED="false"
SELF_TEST_RATE_LIMIT_PER_HOUR="5"
PUBLIC_AGENT_SUBMISSIONS_ENABLED="false"
EXTERNAL_AGENT_ENDPOINT_SUBMISSIONS_ENABLED="false"
AGENT_SUBMISSION_RATE_LIMIT_PER_DAY="3"

# Required before deploying publicly. Generate long random values.
ADMIN_API_KEY="replace-with-a-long-random-admin-secret"
ADMIN_LOGIN_RATE_LIMIT_PER_HOUR="10"
CRON_SECRET="replace-with-a-long-random-cron-secret"
RATE_LIMIT_SALT="replace-with-a-long-random-rate-limit-salt"

# Abuse limits and retention.
VOTE_RATE_LIMIT_PER_HOUR="30"
IDENTITY_CHALLENGE_RATE_LIMIT_PER_HOUR="20"
JOB_LOCK_TIMEOUT_MS="600000"
BATTLE_JOB_RETENTION_DAYS="14"
APP_EVENT_RETENTION_DAYS="30"
SEED_DEMO_DATA="false"

# Optional telemetry. Leave blank unless configured.
SENTRY_DSN=""
POSTHOG_PROJECT_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"
OBSERVABILITY_CAPTURE_APP_EVENTS="false"
